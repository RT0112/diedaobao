<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- ========== 跌倒守护卡片 ========== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_guardian"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️ 跌倒守护"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="未启动"
                    android:textSize="28sp"
                    android:textColor="#F44336"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_status_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="点击下方按钮开启守护"
                    android:textSize="16sp"
                    android:textColor="#666666" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_toggle"
                    android:layout_width="220dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:text="开启守护"
                    android:textSize="22sp"
                    android:backgroundTint="#4CAF50" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== 家属绑定码卡片 ========== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_bind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔗 家属绑定"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="将绑定码告知家属，在子女端输入即可绑定"
                    android:textSize="14sp"
                    android:textColor="#999999" />

                <TextView
                    android:id="@+id/tv_bind_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="------"
                    android:textSize="44sp"
                    android:textColor="#1976D2"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tv_bind_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#999999" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_bind_code"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="200dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="生成绑定码"
                    android:textSize="16sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
